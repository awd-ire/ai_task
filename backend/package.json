{
  "name": "ai-task-manager-backend",
  "version": "1.0.0",
  "description": "AI Task Manager REST API",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js", 
    "build-client": "cd ../frontend && npm install && npm run build",

    "copy-client": "mkdir -p public && cp -r ../frontend/dist/frontend/browser/* public/",

    "render-build": "npm install && npm run build-client && npm run copy-client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "sequelize": "^6.28.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}

